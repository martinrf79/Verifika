# No subir a Cloud Build: entornos virtuales (enormes), secretos y artefactos.
# El Dockerfile solo copia app/ y data/, esto ademas acelera y protege el upload.

# Entornos virtuales
winvenv/
venv/
venv-win/
.venv/

# Secretos locales, NUNCA subir
.secrets.env
*.env

# Artefactos y temporales
*.zip
__pycache__/
*.pyc
*.pyo

# Control de versiones
.git/
.gitignore

# Datos de prueba y tienda simulada: prod lee de Firestore, NO de estos archivos.
# Evita subir el catalogo de 2000 y su embeddings.json (~40MB) de gusto.
reports/
data/clientes/verifika_2k/
data/preguntas_*.jsonl
data/mini_*.jsonl
**/embeddings.json

# Scripts de diagnostico y parches locales
_*
*.bak*
reparar_*
aplicar_*
verify_*
