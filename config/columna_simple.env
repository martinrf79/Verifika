# ════════════════════════════════════════════════════════════════════
# columna_simple.env — el termino medio de Martin (16-jun)
# ════════════════════════════════════════════════════════════════════
# DOS CARRILES sobre el orchestrator que YA existe, sin codigo nuevo:
#   - Carril de datos (codigo): la franja determinista corre cada turno,
#     busca por codigo desde el mensaje, tiene los datos AUNQUE el LLM no
#     llame tools.
#   - Carril de conversacion (LLM): UNA sola llamada, vende libre, nunca es
#     dueno de los datos.
#   - Garantia de salida: el bloque determinista se estampa si o si (render).
#
# Es un PRESET de flags que ya existen. Se carga DESPUES de .secrets6.env y
# .secrets8.env, asi pisa lo que tiene que ir apagado. Apagar todo = no cargar
# este archivo (el bot vuelve a su estado normal byte por byte).
# ════════════════════════════════════════════════════════════════════

# ── Modelo: Gemini 2.5 Flash ──
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# ── UNA sola llamada al LLM (saca el interpretador; el Solver interpreta via tools) ──
USE_INTERPRETER=false

# ── CARRIL DE DATOS: la franja determinista (corre cada turno, busca por codigo) ──
PROVIDER=true
ESTADO_PEDIDO=true
REGISTRO_SESION=true
CARRITO_DELTA=true
CARRITO_VIGENTE=true
PEDIDO_MULTI=true
PEDIDO_PENDIENTE=true
BUSQUEDA_POR_CODIGO=true
BUSQUEDA_RELAJADA=true
STOCK_GATE=true
CALC_DEFENSIVA=true

# ── Prompt corto + tools curadas (search, ficha, calculadora, faq, tarifa CP) ──
PROMPT_LIGERO=true
PROMPT_VENTA=false
PROMPT_CONSTITUCION=false
TOOLS_MINIMAS=true
ENVIO_POR_ZONA=true
TARIFA_PROVINCIA=true

# ── Preguntas de confirmacion + preguntas puente ──
CONFIRMACION_PROVIDER=true
PUENTES_VENTA=true

# ── GARANTIA DE SALIDA: reconciliar y estampar (la franja es la unica autoridad) ──
RENDER_CODIGO=true
VERIFICADOR_MODE=on
VERIFICADOR_AUTOCORRIGE=true
PISO_PRESUPUESTO=shadow

# ── Cierre (handoff + link de Mercado Pago, ya existentes) ──
USE_LEADS=true
LINK_PAGO=true
CIERRE_CONTRATO=true
CIERRE_REQUIERE_PRESUPUESTO=true
CIERRE_SIEMBRA_INICIAL=true
LEADS_NO_PIDE_EN_FALLBACK=true
CIERRE_FORZADO_MAX_ITER=true

# ── Helpers que se quedan prendidos (no compiten, ayudan a la franja) ──
ANTI_JAILBREAK=on
AUTOFIX=true
RESCATE_TOOLCALL_TEXTO=true
TELEMETRIA_TURNO=true
NUEVA_COMPRA_RESET=true
QUERY_PLATA_FUERA=true
EVIDENCIA_REGISTRO=true
FAQ_MATCH_PALABRAS=true
COTIZA_TRANSFERENCIA=true

# ── APAGAR LO DEMAS literalmente (las capas que competian) ──
COMPUERTA_UNICA=false
NUCLEO_FUENTE_VERDAD=false
FAQ_DIRECTO=false
CORRECTOR_ANCLADO=false
CHECKER_GATEA=false
VERIFICADOR_SERVICIOS=off
VERIFICADOR_HECHOS=off
DIRECTOR_LLM=false
CAMINO_NUEVO=false
MODO_LIBRE=false
LIBRO_ASIENTOS=false
USE_VERIFIKA=false
