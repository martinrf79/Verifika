# ════════════════════════════════════════════════════════════════════
# CAMINO NUEVO — preset de la columna limpia (5 pasos, 2 LLM)
# ════════════════════════════════════════════════════════════════════
# Es la maquina determinista MAS la columna nueva. Con CAMINO_NUEVO on, el
# orchestrator delega TODO el turno a app/core/camino_nuevo.py: interprete que
# emite comandos -> director -> provider -> estado_pedido -> redactor + render.
# Las capas legacy del orchestrator no corren (la delegacion las saltea), pero
# los SUB-FLAGS de las herramientas que la columna llama (provider, estado,
# confirmacion, leads, cierre) tienen que estar ON, por eso se conservan.
#
# Uso:
#   $env:BANCO_PRESET="config/camino_nuevo.env"
#   .\correr_local.ps1 py scripts\banco_cierre.py --solo cierre_completo
# ════════════════════════════════════════════════════════════════════

# ── La columna nueva y su dependencia dura ──
CAMINO_NUEVO=true
DIRECTOR_LLM=true

# Anti-jailbreak: corre ANTES de la columna (filtro de entrada por codigo).
ANTI_JAILBREAK=on

# ── Proveedor ──
LLM_PROVIDER=deepseek
INTERPRETER_PROVIDER=deepseek
MAX_OUTPUT_TOKENS=800

# ── 1) MOTOR: interprete + determinista (el redactor reemplaza al Solver) ──
USE_INTERPRETER=true
PROVIDER=true
ESTADO_PEDIDO=true
RENDER_CODIGO=true

# ── 2) MEMORIA ENTRE TURNOS ──
REGISTRO_SESION=true
CARRITO_VIGENTE=true
EVIDENCIA_REGISTRO=true
NUEVA_COMPRA_RESET=true

# ── 3) FICHA / BUSQUEDA ──
BUSQUEDA_POR_CODIGO=true
STOCK_GATE=true
QUERY_PLATA_FUERA=true

# ── 4) CP / ENVIO ──
CP_COMPLETO=true
TARIFA_PROVINCIA=true

# ── 5) CIERRE + LEAD (la capa que cierra y genera el link) ──
USE_LEADS=true
CIERRE_CONTRATO=true
CIERRE_REQUIERE_PRESUPUESTO=true
CIERRE_SIEMBRA_INICIAL=true
LINK_PAGO=true
LEADS_NO_PIDE_EN_FALLBACK=true
COTIZA_TRANSFERENCIA=true

# ── 6) CONFIRMACION + DELTA (la columna usa el director, no carrito_delta) ──
CONFIRMACION_PROVIDER=true
PEDIDO_MULTI=true
PEDIDO_PENDIENTE=true
INTENCION_MANDA=true

# ── 7) PUENTE + ANTI-FALLBACK + VENTA + TELEMETRIA ──
PUENTES_VENTA=true
PROMPT_VENTA=true
NO_RESALUDO=true
ESTADO_NO_REGRESA_SALUDO=true
TELEMETRIA_TURNO=true
TOOLS_MINIMAS=true

# ── APAGADO EXPLICITO: capas competidoras LLM (la columna no las usa) ──
USE_VERIFIKA=false
VERIFICADOR_MODE=off
VERIFICADOR_SERVICIOS=off
VERIFICADOR_HECHOS=off
VERIFICADOR_AUTOCORRIGE=false
COMPUERTA_UNICA=false
CHECKER_GATEA=false
CORRECTOR_ANCLADO=false
AUTOFIX=false
LIBRO_ASIENTOS=false
NUCLEO_FUENTE_VERDAD=false
FAQ_DIRECTO=false
PROMPT_LIGERO=false
COTIZA_CODIGO=false
PRESUPUESTO_AB=false
RESOLVER_PEDIDO=false
