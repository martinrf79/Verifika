# ════════════════════════════════════════════════════════════════════
# MAQUINA DETERMINISTA — preset canonico (fuente unica de verdad)
# ════════════════════════════════════════════════════════════════════
# Este archivo define EXACTAMENTE las herramientas que quedan prendidas:
# interprete + codigo dan el mensaje estructurado, la capa determinista junto
# al Solver devuelve la respuesta, y entre turnos la memoria arranca con el
# contexto que el cliente ya fue dando. Lo que probamos en el banco_cierre es
# lo que se deploya: ambos leen este mismo archivo.
#
# Solo flags (sin secretos). El banco lo carga ANTES de importar el orchestrator;
# en local, correr_local.ps1 lo carga DESPUES de .secrets6.env (este manda en
# los flags, .secrets6.env aporta las claves). En Cloud Run, mapea 1 a 1 a
# --update-env-vars.
#
# Regla: lo que NO esta aca en true queda en su default OFF. Las capas de
# verificacion LLM, compuerta, corrector, checker, autofix, libro y los
# cotizadores legacy quedan APAGADOS a proposito (PROVIDER los consolida).
# ════════════════════════════════════════════════════════════════════

# ── Proveedor: DeepSeek en las tres patas (el de prod, maneja bien las tools) ──
LLM_PROVIDER=deepseek
INTERPRETER_PROVIDER=deepseek

# Tope de salida del Solver. 800 alcanza para el cierre completo; 1200 solo
# alarga la respuesta y gasta de mas.
MAX_OUTPUT_TOKENS=800

# ════════════════════════════════════════════════════════════════════
# 1) MOTOR — interprete (mensaje estructurado) + determinista + Solver
# ════════════════════════════════════════════════════════════════════
USE_INTERPRETER=true
PROVIDER=true
ESTADO_PEDIDO=true
RENDER_CODIGO=true

# ════════════════════════════════════════════════════════════════════
# 2) MEMORIA ENTRE TURNOS — arranca cada turno con el contexto acumulado
#    (ids vistos, carrito vigente, evidencia de lo mostrado) y se suelta a
#    pedido del cliente ("nueva compra", "empezar de cero").
# ════════════════════════════════════════════════════════════════════
REGISTRO_SESION=true
CARRITO_VIGENTE=true
EVIDENCIA_REGISTRO=true
NUEVA_COMPRA_RESET=true

# ════════════════════════════════════════════════════════════════════
# 3) FICHA / BUSQUEDA — la entrada al producto. La ficha no vende stock 0 y
#    la consulta no fabrica un total desde busqueda basura.
# ════════════════════════════════════════════════════════════════════
BUSQUEDA_POR_CODIGO=true
STOCK_GATE=true
QUERY_PLATA_FUERA=true

# ════════════════════════════════════════════════════════════════════
# 4) CP / ENVIO — codigo postal entero + tarifa exacta por provincia
# ════════════════════════════════════════════════════════════════════
CP_COMPLETO=true
TARIFA_PROVINCIA=true

# ════════════════════════════════════════════════════════════════════
# 5) CIERRE + LEAD — cierre desde el contrato real, total verificado -> link
#    de pago, captura de datos del cliente (sin pedirlos sobre un fallback ni
#    sin presupuesto), descuento por transferencia al calculo.
# ════════════════════════════════════════════════════════════════════
CIERRE_CONTRATO=true
CIERRE_REQUIERE_PRESUPUESTO=true
CIERRE_SIEMBRA_INICIAL=true
LINK_PAGO=true
LEADS_NO_PIDE_EN_FALLBACK=true
COTIZA_TRANSFERENCIA=true

# ════════════════════════════════════════════════════════════════════
# 6) CONFIRMACION + DELTA — preguntas de confirmacion por codigo (dato doble
#    A/B desde los candidatos reales) y actualizacion del carrito cuando el
#    cliente cambia de decision (agrega / saca / cambia cantidad / pendiente).
# ════════════════════════════════════════════════════════════════════
CONFIRMACION_PROVIDER=true
CARRITO_DELTA=true
PEDIDO_MULTI=true
PEDIDO_PENDIENTE=true
# El mensaje NUEVO manda: ante una pregunta (no compra/dato), el provider ignora
# el carrito de memoria y no arrastra el presupuesto viejo. Cierre VERDE 15-jun.
INTENCION_MANDA=true

# ════════════════════════════════════════════════════════════════════
# 7) PUENTE + ANTI-FALLBACK + VENTA + SALUDO + TELEMETRIA
#    PUENTES_VENTA: los 7 puentes que sostienen la venta cuando NO hay dato.
#    CIERRE_FORZADO_MAX_ITER: si el Solver agota iteraciones, una ultima pasada
#      cierra con lo que junto en vez de tirar "problema tecnico".
# ════════════════════════════════════════════════════════════════════
PUENTES_VENTA=true
CIERRE_FORZADO_MAX_ITER=true
PROMPT_VENTA=true
SALUDO_CODIGO=true
CATALOGO_CODIGO=true
SOLVER_CODIGO=true
NO_RESALUDO=true
ESTADO_NO_REGRESA_SALUDO=true
TELEMETRIA_TURNO=true
TOOLS_MINIMAS=true

# ════════════════════════════════════════════════════════════════════
# APAGADO EXPLICITO — capas que NO transportan dato (se aislan para la prueba)
# Quedan en off aunque .secrets6.env las traiga en true.
# ════════════════════════════════════════════════════════════════════
# USE_VERIFIKA es el flag MAESTRO del pipeline checker LLM (proposer + checker).
# Apagar los sub-flags no alcanza: si este queda on, el checker corre igual y un
# checker_json_invalid intermitente (visto en prod 14-jun con 23 afirmaciones)
# bloquea y cae al puente sin_precio en una consulta normal. La planilla es la
# autoridad; el checker LLM es capa competidora -> off.
USE_VERIFIKA=false
VERIFIKA_BLOQUEAR_CONTRADICHAS=false
VERIFICADOR_MODE=off
VERIFICADOR_SERVICIOS=off
VERIFICADOR_HECHOS=off
VERIFICADOR_AUTOCORRIGE=false
COMPUERTA_UNICA=false
CHECKER_GATEA=false
CORRECTOR_ANCLADO=false
AUTOFIX=false
LIBRO_ASIENTOS=false
PROMPT_CONSTITUCION=false
NUCLEO_FUENTE_VERDAD=false
FAQ_DIRECTO=false
PROMPT_LIGERO=false
COTIZA_CODIGO=false
PRESUPUESTO_AB=false
RESOLVER_PEDIDO=false
