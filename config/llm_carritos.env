# ════════════════════════════════════════════════════════════════════
# llm_carritos.env — el LLM maneja el carrito SOLO (16-jun)
# ════════════════════════════════════════════════════════════════════
# Decision de Martin tras ver el carrito fantasma: DESCONECTAR toda la franja
# determinista (pedido_pendiente, pedido_multi, carrito_vigente, carrito_delta,
# provider, estado_pedido, confirmacion, render, registro, busqueda por codigo)
# y dejar que el LLM maneje el carrito por su cuenta, con tool calling y su
# memoria de turnos (el historial). Una sola llamada, Gemini.
#
# Pregunta que responde: el LLM, con solo el historial + calculate_total + search,
# puede armar, modificar y totalizar un carrito a lo largo de la charla?
#
# Se carga DESPUES de .secrets6.env + .secrets8.env. Todos flags EXISTENTES.
# Volver = no cargarlo (o cargar columna_simple.env).
# ════════════════════════════════════════════════════════════════════

# Modelo + una sola llamada
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
USE_INTERPRETER=false

# ── DESCONECTAR LA FRANJA DETERMINISTA (lo que causaba el carrito fantasma) ──
PROVIDER=false
ESTADO_PEDIDO=false
PEDIDO_PENDIENTE=false
PEDIDO_MULTI=false
CARRITO_VIGENTE=false
CARRITO_DELTA=false
CONFIRMACION_PROVIDER=false
RENDER_CODIGO=false
REGISTRO_SESION=false
RESOLVER_PEDIDO=false
COTIZA_CODIGO=false
PRESUPUESTO_AB=false
BUSQUEDA_POR_CODIGO=false
DIRECTOR_LLM=false
CAMINO_NUEVO=false

# ── EL LLM CON SUS TOOLS (search, ficha, calculadora, faq, tarifa CP) + memoria ──
TOOLS_MINIMAS=true
ENVIO_POR_ZONA=true
TARIFA_PROVINCIA=true
BUSQUEDA_RELAJADA=true
CALC_DEFENSIVA=true
PROMPT_LIGERO=true
PROMPT_VENTA=false
PUENTES_VENTA=true

# ── Unica red de seguridad: el verificador de numeros (no estampa, solo frena
#    cifras sin respaldo de las tools). No es franja, es el piso anti-invento. ──
VERIFICADOR_MODE=on
VERIFICADOR_AUTOCORRIGE=true
AUTOFIX=true

# ── Cierre (handoff + link MP) sigue por la capa de leads ──
USE_LEADS=true
LINK_PAGO=true

# ── Apagar el resto de capas que compiten ──
COMPUERTA_UNICA=false
NUCLEO_FUENTE_VERDAD=false
FAQ_DIRECTO=false
CORRECTOR_ANCLADO=false
CHECKER_GATEA=false
VERIFICADOR_SERVICIOS=off
VERIFICADOR_HECHOS=off
LIBRO_ASIENTOS=false
MODO_LIBRE=false
USE_VERIFIKA=false
PISO_PRESUPUESTO=shadow
