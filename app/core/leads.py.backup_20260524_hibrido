"""
LEADS - captura automatica de leads de venta.

Detecta intencion de compra por palabras clave, pide nombre y telefono
al cliente, guarda el lead en Firestore y notifica al dueno por Telegram.

Feature flag: USE_LEADS=true para activarlo. False por default.

Estados de un lead:
- intencion_detectada: bot detecto intencion pero todavia no pidio datos
- datos_solicitados: bot ya pidio nombre y telefono, esperando respuesta
- capturado: cliente dio los datos, lead completo
"""
import os
import re
import time
from google.cloud import firestore
from app.config import get_settings
from app.logger import get_logger
from app.storage.firestore_client import _tienda_ref, _get_db
from app.core.notificador import notificar_lead

log = get_logger(__name__)
settings = get_settings()

USE_LEADS = os.getenv("USE_LEADS", "false").lower() == "true"

# Ventana de tiempo en segundos para considerar un lead activo
LEAD_VENTANA_SEGUNDOS = 24 * 60 * 60

# Palabras y frases que disparan intencion de compra
PALABRAS_INTENCION = [
    "lo quiero", "la quiero", "los quiero", "las quiero",
    "lo llevo", "la llevo", "los llevo", "las llevo",
    "me lo guardas", "me la guardas", "me lo reservas", "me la reservas",
    "como pago", "como compro", "donde pago", "donde compro",
    "hacen envio", "hacen envios", "mandan a", "mandas a",
    "cuanto sale el envio", "cuanto cuesta el envio",
    "tenes stock", "hay stock", "tienen stock",
    "lo necesito", "la necesito",
    "me sirve", "me conviene",
    "lo voy a llevar", "la voy a llevar",
    "ok cerrado", "cerramos", "dale cerrado",
    "pasame el link", "mandame el link",
    "como hago para comprar", "como hago para llevarlo",
]

# Regex para detectar telefono argentino con o sin codigo de pais
RE_TELEFONO = re.compile(
    r"(?:\+?54\s?9?\s?)?(?:11|2\d{2}|3\d{2})\s?\d{3,4}\s?\d{4}"
)

# Regex para detectar telefonos genericos de 8 a 13 digitos
RE_TELEFONO_GENERICO = re.compile(r"\b\d{8,13}\b")


def detectar_intencion(mensaje: str) -> tuple[bool, str]:
    """
    Detecta si el mensaje muestra intencion de compra.
    Devuelve tupla bool con frase disparadora si hubo match.
    """
    if not mensaje:
        return False, ""
    msg_lower = mensaje.lower()
    for frase in PALABRAS_INTENCION:
        if frase in msg_lower:
            return True, frase
    return False, ""


def extraer_telefono(texto: str) -> str:
    """
    Extrae primer telefono que aparezca en el texto.
    Devuelve solo digitos, string vacio si no encuentra.
    """
    if not texto:
        return ""
    match = RE_TELEFONO.search(texto)
    if match:
        return re.sub(r"\D", "", match.group(0))
    match = RE_TELEFONO_GENERICO.search(texto)
    if match:
        return match.group(0)
    return ""


def extraer_nombre(texto: str) -> str:
    """
    Extrae nombre con heuristica simple.
    Busca patron tipo soy Juan, me llamo Maria, mi nombre es Carlos.
    Si no encuentra patron, devuelve string vacio.
    """
    if not texto:
        return ""
    patrones = [
        r"soy\s+([A-Z\u00c1\u00c9\u00cd\u00d3\u00da\u00d1][a-z\u00e1\u00e9\u00ed\u00f3\u00fa\u00f1]+(?:\s+[A-Z\u00c1\u00c9\u00cd\u00d3\u00da\u00d1][a-z\u00e1\u00e9\u00ed\u00f3\u00fa\u00f1]+)?)",
        r"me llamo\s+([A-Z\u00c1\u00c9\u00cd\u00d3\u00da\u00d1][a-z\u00e1\u00e9\u00ed\u00f3\u00fa\u00f1]+(?:\s+[A-Z\u00c1\u00c9\u00cd\u00d3\u00da\u00d1][a-z\u00e1\u00e9\u00ed\u00f3\u00fa\u00f1]+)?)",
        r"mi nombre es\s+([A-Z\u00c1\u00c9\u00cd\u00d3\u00da\u00d1][a-z\u00e1\u00e9\u00ed\u00f3\u00fa\u00f1]+(?:\s+[A-Z\u00c1\u00c9\u00cd\u00d3\u00da\u00d1][a-z\u00e1\u00e9\u00ed\u00f3\u00fa\u00f1]+)?)",
    ]
    for pat in patrones:
        m = re.search(pat, texto, re.IGNORECASE)
        if m:
            return m.group(1).strip().title()
    return ""


def get_lead_activo(user_id: str, canal: str, tienda_id: str) -> dict | None:
    """
    Busca el lead mas reciente del cliente en la ventana de 24h.
    Devuelve dict con datos del lead o None si no hay.
    """
    try:
        leads_ref = _tienda_ref(tienda_id).collection("leads")
        cutoff_ts = time.time() - LEAD_VENTANA_SEGUNDOS
        query = (leads_ref
                 .where(filter=firestore.FieldFilter("user_id", "==", user_id))
                 .where(filter=firestore.FieldFilter("canal", "==", canal))
                 .order_by("creado_en_ts", direction=firestore.Query.DESCENDING)
                 .limit(1))
        docs = list(query.stream())
        if not docs:
            return None
        data = docs[0].to_dict()
        data["lead_id"] = docs[0].id
        if data.get("creado_en_ts", 0) < cutoff_ts:
            return None
        return data
    except Exception as e:
        log.warning("lead_query_failed", error=str(e)[:120])
        return None


def crear_lead(user_id: str, canal: str, tienda_id: str,
               ultimo_mensaje: str, frase_disparadora: str,
               productos_de_interes: list[str] | None = None) -> str:
    """
    Crea un lead nuevo en estado intencion_detectada.
    Devuelve el lead_id creado.
    """
    leads_ref = _tienda_ref(tienda_id).collection("leads")
    doc_ref = leads_ref.document()
    doc_ref.set({
        "tienda_id": tienda_id,
        "canal": canal,
        "user_id": user_id,
        "nombre": "",
        "telefono": "",
        "estado": "intencion_detectada",
        "ultimo_mensaje": ultimo_mensaje[:500],
        "frase_disparadora": frase_disparadora,
        "productos_de_interes": productos_de_interes or [],
        "creado_en": firestore.SERVER_TIMESTAMP,
        "creado_en_ts": time.time(),
        "actualizado_en": firestore.SERVER_TIMESTAMP,
    })
    log.info("lead_created", lead_id=doc_ref.id, tienda_id=tienda_id,
             user_id=user_id, canal=canal)
    return doc_ref.id


def actualizar_lead(lead_id: str, tienda_id: str, cambios: dict):
    """Actualiza un lead existente con los cambios dados."""
    cambios["actualizado_en"] = firestore.SERVER_TIMESTAMP
    _tienda_ref(tienda_id).collection("leads").document(lead_id).update(cambios)


async def procesar_mensaje_para_lead(
    user_id: str,
    canal: str,
    tienda_id: str,
    mensaje: str,
    respuesta_solver: str,
    trace_id: str,
) -> tuple[str | None, dict]:
    """
    Funcion principal del modulo.
    Decide que hacer segun el estado actual del lead y el mensaje del cliente.

    Devuelve tupla con:
    - respuesta_extra: texto a agregar a la respuesta del bot, o None
    - meta: dict con info para logs

    Estados posibles de salida:
    - lead nuevo creado, bot pide datos
    - lead existente en datos_solicitados, cliente dio datos, marcamos capturado
    - lead existente en datos_solicitados, cliente no dio datos, no hacemos nada
    - no hay intencion ni lead activo, no hacemos nada
    """
    meta = {"accion": "ninguna"}

    lead_activo = get_lead_activo(user_id, canal, tienda_id)

    # Caso uno, ya hay lead esperando datos del cliente
    if lead_activo and lead_activo.get("estado") == "datos_solicitados":
        nombre = extraer_nombre(mensaje)
        telefono = extraer_telefono(mensaje)
        if nombre or telefono:
            cambios = {"estado": "capturado", "ultimo_mensaje": mensaje[:500]}
            if nombre:
                cambios["nombre"] = nombre
            if telefono:
                cambios["telefono"] = telefono
            actualizar_lead(lead_activo["lead_id"], tienda_id, cambios)
            log.info("lead_capturado", lead_id=lead_activo["lead_id"],
                     tienda_id=tienda_id, user_id=user_id,
                     tiene_nombre=bool(nombre), tiene_telefono=bool(telefono),
                     trace_id=trace_id)
            try:
                await notificar_lead(
                    tienda_id=tienda_id,
                    user_id=user_id,
                    canal=canal,
                    estado="capturado",
                    nombre=nombre,
                    telefono=telefono,
                    ultimo_mensaje=mensaje,
                )
            except Exception as e:
                log.warning("notificar_lead_failed", error=str(e)[:120])
            meta["accion"] = "lead_capturado"
            meta["lead_id"] = lead_activo["lead_id"]
            extra = "\n\nGracias, ya le aviso al dueno para coordinar con vos."
            return extra, meta
        return None, {"accion": "ninguna"}

    # Caso dos, no hay lead pero el mensaje muestra intencion
    tiene_intencion, frase = detectar_intencion(mensaje)
    if tiene_intencion:
        lead_id = crear_lead(
            user_id=user_id,
            canal=canal,
            tienda_id=tienda_id,
            ultimo_mensaje=mensaje,
            frase_disparadora=frase,
        )
        actualizar_lead(lead_id, tienda_id, {"estado": "datos_solicitados"})
        log.info("intencion_compra_detectada", lead_id=lead_id,
                 tienda_id=tienda_id, user_id=user_id,
                 frase=frase, trace_id=trace_id)
        try:
            await notificar_lead(
                tienda_id=tienda_id,
                user_id=user_id,
                canal=canal,
                estado="intencion_detectada",
                nombre="",
                telefono="",
                ultimo_mensaje=mensaje,
            )
        except Exception as e:
            log.warning("notificar_lead_failed", error=str(e)[:120])
        meta["accion"] = "datos_solicitados"
        meta["lead_id"] = lead_id
        extra = "\n\nPara avanzar con tu pedido, me pasas tu nombre y un telefono donde contactarte?"
        return extra, meta

    return None, {"accion": "ninguna"}
